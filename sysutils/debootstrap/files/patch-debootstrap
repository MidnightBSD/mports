@@ -564,7 +558,18 @@
 		FreeBSD*)
 			HOST_OS=freebsd
 		;;
+		MidnightBSD*)
+			HOST_OS=midnightbsd
+		;;
 	esac
+fi
+
+if [ "$HOST_OS" = "midnightbsd" -a -z "$HOST_ARCH" ]; then
+	HOST_ARCH=`/sbin/sysctl -n hw.machine_arch`
