--- debootstrap.orig	2024-12-29 13:30:24.000000000 -0500
+++ debootstrap	2026-04-19 13:20:26.855001000 -0400
@@ -1,4 +1,4 @@
-#!/bin/sh
+#!/usr/local/bin/bash
 set -e
 
 VERSION='@VERSION@'
