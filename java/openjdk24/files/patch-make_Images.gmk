--- make/Images.gmk.orig
+++ make/Images.gmk
@@ -77,7 +77,7 @@
     /jdk.localedata/** \
     #
 
-JLINK_TOOL := $(JLINK) -J-Djlink.debug=true \
+JLINK_TOOL := $(JLINK) -J-Djlink.debug=true -J-XX:TieredStopAtLevel=1 -J-XX:+UseSerialGC \
     --module-path $(call PathList, $(JMODS_DIRS)) \
     --endian $(OPENJDK_TARGET_CPU_ENDIAN) \
     --release-info $(BASE_RELEASE_FILE) \
