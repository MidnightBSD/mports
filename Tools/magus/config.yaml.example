PkgfilesRoot: /usr/magus/packages
DistfilesRoot: /usr/magus/distfiles
PkgExtension: mport
WorkerPhases:
  - build
  - fetch
  - scan
  - test
ClamAVScanner: clamscan
ClamAVOptions: --no-summary
YaraScanner: yara
YaraRules: /usr/magus/slave-data/mports/Tools/magus/yara/mports-shell.yar
YaraOptions:
