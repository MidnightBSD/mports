--- config/jvm.options.orig	2026-06-23 19:58:26 UTC
+++ config/jvm.options
@@ -79,7 +79,7 @@
 # -XX:HeapDumpPath=/heap/dump/path
  
 # specify an alternative path for JVM fatal error logs
--XX:ErrorFile=hs_err_pid%p.log
+-XX:ErrorFile=${ES_TMPDIR}/hs_err_pid%p.log
 
 ## GC logging
--Xlog:gc*,gc+age=trace,safepoint:file=gc.log:utctime,level,pid,tags:filecount=32,filesize=64m
+-Xlog:gc*,gc+age=trace,safepoint:file=${ES_TMPDIR}/gc.log:utctime,level,pid,tags:filecount=32,filesize=64m
