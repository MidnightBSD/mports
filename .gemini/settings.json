{
  "general": {
    "defaultApprovalMode": "auto_edit",
    "plan": {
      "enabled": true,
      "modelRouting": true
    }
  },
  "tools": {
    "excludeTools": [
      "ShellTool(rm -rf /)",
      "ShellTool(shutdown)",
      "ShellTool(kldload)",
      "ShellTool(kldunload)"
    ],
    "core": [
      "run_shell_command(bmake)",
      "run_shell_command(make)",
      "run_shell_command(ninja)",
      "run_shell_command(gmake)",
      "run_shell_command(cmake)",
      "run_shell_command(mvn)",
      "run_shell_command(gradle)",
      "run_shell_command(ant)",
      "run_shell_command(cargo)",
      "run_shell_command(npm)",
      "run_shell_command(git)",
      "run_shell_command(ps)",
      "run_shell_command(mkdir)",
      "run_shell_command(ls)",
      "run_shell_command(cp)",
      "run_shell_command(mv)",
      "run_shell_command(rm)",
      "run_shell_command(rmdir)",
      "run_shell_command(pwd)",
      "run_shell_command(cat)",
      "run_shell_command(chmod)",
      "run_shell_command(chown)",
      "run_shell_command(touch)",
      "run_shell_command(echo)",
      "run_shell_command(portlint)",
      "run_shell_command(portfmt)",
      "run_shell_command(sh)",
      "run_shell_command(bash)",
      "run_shell_command(mksh)",
      "run_shell_command(sed)",
      "run_shell_command(awk)",
      "run_shell_command(gh)",
      "run_shell_command(rg)",
      "run_shell_command(curl)",
      "read_file",
      "write_file",
      "list_directory",
      "glob",
      "grep_search",
      "replace",
      "magus:get_port_log",
      "magus:get_port_details",
      "magus:lookup_port"
    ]
  },
  "context": {
    "fileName": ["AGENTS.md"]
  },
  "hooks": {
    "BeforeTool": [
      {
        "name": "audit-before-write",
        "matcher": "write_file|replace",
        "type": "command",
        "command": "./.gemini/hooks/security-audit.sh"
      }
    ]
  },
  "planning": {
    "skills": ["Security Auditor"],
    "enforceSecurityCheck": true
  },
  "mcp": {
    "allowed": ["magus"]
  }
}
